{
  "name": "hcm-land-map-mvp",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "db:setup": "psql -U postgres -h localhost -p 5432 -f scripts/setup-db.sql",
    "db:setup:auth": "node scripts/setup-auth.js",
    "db:status": "node scripts/db-status.js",
    "db:restore": "node scripts/restore-db.js",
    "db:export": "node scripts/export-db.js",
    "db:export:geocode-excel": "node scripts/export-geocode-excel.js",
    "db:import": "node scripts/import-full.js",
    "db:import:append": "node scripts/import-append.js",
    "db:dedupe": "node scripts/dedupe-land-parcels.js",
    "db:fix-geometries": "node scripts/fix-land-parcel-geometries.js",
    "db:apply-geometry-repair": "node scripts/apply-geometry-repair.js",
    "db:docker:up": "docker compose -f docker-compose.postgis.yml up -d",
    "db:docker:pgadmin": "docker compose -f docker-compose.postgis.yml up -d pgadmin",
    "db:docker:down": "docker compose -f docker-compose.postgis.yml down",
    "db:docker:export": "node scripts/docker-export-db.js",
    "db:docker:restore": "node scripts/docker-restore-db.js",
    "db:docker:status": "node scripts/docker-db-status.js",
    "db:docker:setup": "node scripts/docker-hcm-pilot-setup.js",
    "db:docker:setup:reset": "node scripts/docker-hcm-pilot-setup.js --reset",
    "db:docker:sync:app": "node scripts/docker-sync-app-tables.js",
    "db:migrate-postgis": "node scripts/migrate-postgis.js",
    "db:maintain-hcm": "node scripts/dedupe-land-parcels.js && node scripts/fix-land-parcel-geometries.js && node scripts/add-performance-indexes.js && npm run es:setup",
    "db:docker:tune": "docker compose -f docker-compose.postgis.yml up -d --force-recreate postgis",
    "tiles:pregen": "node scripts/pregen-tiles.js",
    "tiles:pregen:z16": "node scripts/pregen-tiles.js --kind=land-parcels --min-zoom=16 --max-zoom=16",
    "tiles:pregen:qhsdd": "node scripts/pregen-tiles.js --kind=qhsdd",
    "db:optimize": "node scripts/dedupe-land-parcels.js && npm run es:setup",
    "db:import:force": "node scripts/import-full.js --force",
    "db:import:property-buys": "node scripts/import-property-buys.js",
    "db:import:qhsdd": "node scripts/import-hcm-qhsdd.js",
    "db:backfill-qhsdd-admin": "node scripts/backfill-qhsdd-admin.js",
    "es:up": "docker compose -f docker-compose.elasticsearch.yml up -d",
    "es:down": "docker compose -f docker-compose.elasticsearch.yml down",
    "es:wait": "node scripts/wait-elasticsearch.js",
    "es:index": "node scripts/index-parcels-es.js",
    "es:index:qhsdd": "node scripts/index-qhsdd-es.js",
    "es:setup": "npm run es:up && npm run es:wait && npm run es:index",
    "es:setup:qhsdd": "npm run es:up && npm run es:wait && npm run es:index:qhsdd",
    "dev": "npm run dev --workspace backend",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspace backend && npm run build --workspace frontend",
    "load:tiles": "node scripts/load/tiles-ramp.js",
    "load:mixed": "node scripts/load/mixed-ramp.js",
    "load:map-pan": "node scripts/load/map-pan-ramp.js"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.17.0",
    "papaparse": "^5.5.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "autocannon": "^8.0.0",
    "concurrently": "^9.1.2"
  }
}
