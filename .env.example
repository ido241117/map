PORT=3001
# Local PostgreSQL (chưa PostGIS)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/hcm_land_mvp
# Docker PostGIS MVP — HCM land_parcels + hcm_qhsdd (port 5433)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/hcm_land_mvp
# OSM slim — highways + railways (docker-compose.osm-highways.yml)
OSM_DATABASE_URL=postgres://postgres:postgres@localhost:5435/osm_highways
JWT_SECRET=change-me-in-production
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_PARCELS_INDEX=parcels
# MVT file cache (pre-gen tiles) — đọc disk trước, miss thì PostGIS
TILE_CACHE_ENABLED=1
# Relpath theo cwd backend → ../data/tile-cache; hoặc absolute
# TILE_CACHE_DIR=../data/tile-cache
# Giữ hot tile trong RAM (MB). VPS 8GB nên ~256–512 — giúp 50 user pan mượt hơn disk.
TILE_MEMORY_CACHE_MB=256
# pg.Pool max per process (default 10). Postgres docker hiện max_connections=100.
# Single process: 40 ổn. pm2 cluster N instances: giữ N * PG_POOL_MAX < ~80/DB.
PG_POOL_MAX=40
# OSM_PG_POOL_MAX=40
# Log pool waiting mỗi N ms (0=tắt). Chỉ log khi waiting>0 trừ PG_POOL_LOG_ALWAYS=1.
# PG_POOL_LOG_MS=2000
# UV_THREADPOOL_SIZE: không đặt trong file này (libuv đọc lúc Node start).
# npm run dev / start đã mặc định 64 qua scripts/with-uv-threadpool.js
# Ghi đè: $env:UV_THREADPOOL_SIZE="32"; npm run dev:backend

# Frontend (Vite) — optional; mặc định proxy /api → :3001
# VITE_API_URL=/api

# --- Zoom thresholds (backend + frontend cùng 1 giá trị; restart sau khi đổi) ---
# Serve MVT thửa đất từ zoom này
LAND_PARCELS_MIN_ZOOM=8
# Hiện lớp thửa đất (ranh geometry / MapLibre + viewport API)
PARCELS_GEOMETRY_MIN_ZOOM=16
# Hiện số nhà trên thửa
HOUSE_NO_LABEL_MIN_ZOOM=18
# Hiện / load lớp QHSDD
QHSDD_MIN_ZOOM=8
# Label mã QHSDD (frontend)
QHSDD_LABEL_MIN_ZOOM=16
# Hiện lớp lộ giới
HIGHWAYS_MIN_ZOOM=10
# Hiện lớp đường sắt (line MVT + quy hoạch metro_plan)
RAILWAYS_MIN_ZOOM=0
# Hiện chấm nhà ga (L1 + quy hoạch GeoJSON)
RAILWAYS_STATIONS_MIN_ZOOM=0
